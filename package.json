{
  "name": "shareable-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:setup": "wrangler d1 execute workspaces-db --local --file=schema.sql",
    "dev:local": "npm run dev:setup && concurrently -n \"app,party\" -c \"cyan,green\" \"next dev\" \"npm run party:dev\"",
    "build": "NEXT_DISABLE_TURBOPACK=1 NODE_OPTIONS=--max-old-space-size=4096 next build --no-turbopack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "party:dev": "partykit dev",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf:deploy-cron": "wrangler deploy --config wrangler-cron.toml"
  },
  "dependencies": {
    "next": "16.1.6",
    "partysocket": "^1.1.16",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "partykit": "^0.0.115",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
